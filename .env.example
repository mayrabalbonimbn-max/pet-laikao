DATABASE_URL="postgresql://laikao:trocar_senha@127.0.0.1:5432/laikao?schema=public"

# App base URL. For local browser return flow, localhost is enough.
APP_URL="http://localhost:3000"
PUBLIC_HOST="petlaikao.com.br"
ADMIN_HOST="admin.petlaikao.com.br"
ADMIN_EMAIL="admin@petlaikao.com.br"
ADMIN_PASSWORD="Trocar@123"
STORAGE_PROVIDER="local"
PROMOTION_IMAGE_MAX_BYTES="8388608"
PRODUCT_IMAGE_MAX_BYTES="8388608"

# InfinitePay Checkout Integrado.
# Use your InfiniteTag without the leading "$".
INFINITEPAY_HANDLE=""

# Optional override if InfinitePay changes its public API host.
INFINITEPAY_API_BASE_URL="https://api.infinitepay.io"

# Public URL that InfinitePay can reach from the internet.
# Example after opening a local tunnel:
# INFINITEPAY_WEBHOOK_PUBLIC_URL="https://your-subdomain.loca.lt/api/webhooks/payments"
INFINITEPAY_WEBHOOK_PUBLIC_URL=""

# Optional shared token appended to the webhook URL for local hardening.
# This is an app-side verification layer, not an official InfinitePay signature.
INFINITEPAY_WEBHOOK_SECRET=""
