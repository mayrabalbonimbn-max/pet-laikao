# API propria do Laikao (NestJS). Mesmo Postgres do Next.
DATABASE_URL="postgresql://laikao_user:senha@127.0.0.1:5432/laikao?schema=public"

# Porta dedicada da API (livre na VPS).
PORT=4018

# Ambiente.
NODE_ENV=development

# Prefixo global das rotas (transicao: nginx mapeia /apiv2 -> :4018).
API_GLOBAL_PREFIX=apiv2

# Origens permitidas no CORS (separadas por virgula).
CORS_ORIGINS="https://petlaikao.com.br,https://admin.petlaikao.com.br,http://localhost:3000"

# Cookie de sessao admin (precisa bater com o do Next para compatibilidade).
ADMIN_SESSION_COOKIE=laikao_admin_session

# Cookie secure (true em producao com HTTPS).
COOKIE_SECURE=false
